# Application
APP_ENV=development
PORT=8000
CORS_ORIGIN=http://localhost:3001

# Database (PostgreSQL). Use your managed URL or the local docker-compose one:
# local compose: postgres://cairn:cairn@localhost:5432/cairn?sslmode=disable
DATABASE_URL=

# SMTP (used from Phase 2 for invitation/notification emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Auth
JWT_SECRET=                 # required; generate a long random value
ACCESS_TOKEN_TTL=15m        # access token lifetime
REFRESH_TOKEN_TTL=720h      # refresh token lifetime (30 days)
COOKIE_SECURE=false         # set true in production (HTTPS)

# URLs
APP_BASE_URL=http://localhost:8000   # public URL of this API (OAuth redirect base)
FRONTEND_URL=http://localhost:3001   # public URL of the Next.js app
INVITE_TTL=168h                      # invitation validity (7 days)

# SSO (Google / Microsoft). Leave a provider blank to disable it.
# Google redirect URI:    {APP_BASE_URL}/api/v1/auth/oauth/google/callback
# Microsoft redirect URI: {APP_BASE_URL}/api/v1/auth/oauth/microsoft/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common              # or your Azure AD tenant id

# Billing / subscriptions
PLATFORM_ADMIN_EMAILS=               # comma-separated emails bootstrapped as platform admins
DEFAULT_PRICE_PER_SEAT_CENTS=1200    # default per-seat monthly price for new subscriptions
DEFAULT_CURRENCY=NGN                  # default billing currency (local-first)
